{
  "name": "turnierplan-net",
  "version": "2026.2.0",
  "description": "The client application of turnierplan.NET",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/turnierplan-NET/turnierplan.NET"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 45002",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
